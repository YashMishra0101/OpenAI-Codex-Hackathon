# ─────────────────────────────────────────────────────────────
# Server Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-resume-tracker?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<min-32-character-secret>
JWT_REFRESH_SECRET=<min-32-character-secret>
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Client ────────────────────────────────────────────────────
# Frontend origin — used for CORS
CLIENT_URL=http://localhost:5173

# ── AI — Primary (Google Gemini 3.5 Flash) ───────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# ── AI — Fallback (Groq Qwen 3.6 27B) ───────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key>

# ── Cloudinary ────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Email (Resend SDK) ────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>

# ── Google OAuth ──────────────────────────────────────────────
# Must match VITE_GOOGLE_CLIENT_ID in client/.env
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>

# ── Monitoring ────────────────────────────────────────────────
# Optional — only active in production (NODE_ENV=production)
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=<your-sentry-dsn>
