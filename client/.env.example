# ─────────────────────────────────────────────────────────────
# Client Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────
# Development: Vite proxies /api to localhost:5000, so this points to the proxy.
# Production: set to your Render backend URL.
VITE_API_URL=http://localhost:5000/api/v1

# ── Google OAuth ──────────────────────────────────────────────
# Must match GOOGLE_CLIENT_ID in server/.env
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>

# ── Sentry (optional — only active in production) ─────────────
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
VITE_SENTRY_DSN=<your-sentry-dsn>
